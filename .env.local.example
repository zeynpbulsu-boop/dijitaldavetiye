# ─── Public site URL (used by sitemap, robots, OG, checkout return_url) ───
NEXT_PUBLIC_SITE_URL=https://nuve.app

# ─── Dodo Payments (Merchant of Record) ──────────────────────────────────
# 1. Get a Bearer token from https://app.dodopayments.com/developer/api-keys
# 2. Create three one-time products in the dashboard for the three NUVE tiers
#    and paste the product IDs below.
# 3. Set DODO_PAYMENTS_ENVIRONMENT=test_mode while testing, then flip to
#    live_mode when you're ready to take real money.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode

# Product IDs from the Dodo dashboard (Sentra) — one per pricing tier.
DODO_PRODUCT_SADE=
DODO_PRODUCT_KLASIK=
DODO_PRODUCT_PREMIUM=

# ─── Supabase ────────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Run supabase/migrations/001_init.sql in the SQL editor
# 3. Paste the URL + keys below (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (Resend) ──────────────────────────────────────────
# Get an API key from https://resend.com → API Keys.
# Verify your sending domain (nuve.app) so emails don't land in spam.
# Without this key, the webhook + RSVP routes log a console message
# and silently skip — no crash, just no email.
RESEND_API_KEY=
NUVE_FROM_EMAIL="NUVE <hello@nuve.app>"

# ─── WhatsApp Business API ───────────────────────────────────
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ─── Cloudinary (template image hosting) ─────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
